{
  "crons": [
    {
      "path": "/api/cron/shop-expire-reservations",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/push-dispatch",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/media-processing",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/meet-reminders",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/nexus/health-check",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/nexus/mission-health",
      "schedule": "2-57/5 * * * *"
    },
    {
      "path": "/api/cron/nexus/alert-evaluation",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/nexus/observation-engine",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/nexus/metrics-rollup",
      "schedule": "5 * * * *"
    },
    {
      "path": "/api/cron/nexus/command-suggestions",
      "schedule": "35 * * * *"
    },
    {
      "path": "/api/cron/nexus/command-expiry",
      "schedule": "50 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/push/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store, max-age=0" }]
    }
  ]
}
